{
  "name": "facturacion-profesional",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"vite\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/src/index.ts",
    "test": "jest --config jest.config.cjs",
    "build": "tsc -b && vite build && npm run build:api",
    "build:api": "tsc -p tsconfig.server.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server/dist/index.js",
    "seed:first-tenant": "tsx server/src/seedTenant.ts",
    "smoke:saas": "node scripts/smoke-runtime-config.mjs",
    "deploy": "npm run build && swa deploy ./dist --deployment-token $SWA_DEPLOYMENT_TOKEN --env production"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.5.0",
    "@supabase/supabase-js": "^2.49.8",
    "cors": "^2.8.6",
    "dexie": "^4.0.11",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.1",
    "jspdf": "^3.0.4",
    "lucide-react": "^0.344.0",
    "mssql": "^12.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-to-print": "^2.14.15",
    "recharts": "^2.15.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/mssql": "^9.1.9",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jest": "^30.2.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^6.4.1"
  }
}
